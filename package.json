{
  "name": "billbook",
  "version": "0.1.0",
  "description": "A local-first markdown journal for writing every day",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:mac": "electron-builder --mac dir",
    "install:mac": "node scripts/install-mac.js",
    "setup:mac": "npm run build:mac && npm run install:mac"
  },
  "keywords": [
    "electron",
    "journal",
    "markdown"
  ],
  "productName": "Billbook",
  "author": "William Liu",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.liuwilliam.billbook",
    "productName": "Billbook",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "scripts/**/*",
      "src/**/*",
      "package.json",
      "README.md"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir"
      ]
    }
  }
}
